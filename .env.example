# confirmed-ctl configuration. Copy to `.env` and fill in real values.
# The real .env file is git-ignored and must never be committed.

# Database (your existing Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/your_db

# CRM (MariaDB permtrak2_crm, READ-ONLY lookup adapter — SELECT only, never writes)
# Used by confirmed_ctl/crm/client.py to read ad/case rows from t_e_s_t_p_e_r_m.
# Leave CRM_DB_HOST blank until the cPanel Remote-MySQL allowlist grants the
# server access and a least-privilege read-only grant exists; blank => the
# /candidates and /unconfirmed endpoints return 503 "CRM not configured".
CRM_DB_HOST=
CRM_DB_USER=
CRM_DB_PASS=
CRM_DB_NAME=permtrak2_crm
CRM_DB_PORT=3306

# CRM WRITE-BACK gate (default false — dev/test NEVER write to the live CRM).
# When true, /confirm issues ONE strictly-allowlisted UPDATE to the matched
# t_e_s_t_p_e_r_m record (statclearancenews='["Done"]', trxstring,
# urlgmailadconfirm, datepaidnews — no other columns, param-bound). Set true
# ONLY on fang, where the permtrak2_crm user is granted from fang's IP.
CONFIRMED_CTL_CRM_WRITE=false

# Gmail (read-only, service-account with domain-wide delegation)
# Path to the Google service-account JSON key file (a secret on disk).
GMAIL_TOKEN_PATH=/opt/confirmed-ctl/secrets/google-service-account.json
# Mailbox the service account impersonates. Default karl@perm-ads.com: it holds
# the BofA alerts in its DURABLE INBOX (not Trash) and also receives Paul's info@
# vendor ad-confirmation emails that this tool searches by CRM ad number. The
# scan still lists with includeSpamTrash=True defensively.
# Alternatives (override this value):
#   info@perm-ads.com  — the delivery address; a filter auto-trashes BofA alerts
#                        there and Gmail purges Trash after ~30 days (run daily).
#   <admin mailbox>    — the non-forwarded admin account (e.g. admin@perm-ads.com).
GMAIL_IMPERSONATE=karl@perm-ads.com

# Email-scan ingestion
# Default lookback window (days) for the BofA transaction-alert scan. Keep the
# scan on a DAILY schedule so Trash auto-purge (~30 days) never drops an alert.
EMAIL_SCAN_LOOKBACK_DAYS=2

# Receipts storage
RECEIPTS_BASE_PATH=/mnt/receipts

# ChromaDB
CHROMA_PATH=/opt/confirmed-ctl/chroma_db

# Sync interval for daemon (seconds)
SYNC_INTERVAL_SECONDS=3600

# HTTP API (confirmed_ctl.wsgi:app served by gunicorn — confirmed-ctl-api.service)
# Bearer token guarding every API request. Generate a strong random value on the
# fang service (e.g. `openssl rand -hex 32`) and keep it out of git. When blank,
# the API fails OPEN (no auth) for dev/test — the production service MUST set it.
CONFIRMED_CTL_API_TOKEN=
# Fail-CLOSED switch. Set to 1/true to REFUSE serving when the token is unset
# (protected routes return 503 auth_required_but_unset; /healthz stays exempt).
# Default false keeps the fail-open dev/test behavior (with a loud warning).
CONFIRMED_CTL_REQUIRE_AUTH=false
# Localhost bind for the API (reached from claw/MARS over an SSH tunnel). This is
# the default; the systemd unit expands ${CONFIRMED_CTL_API_BIND} from here.
CONFIRMED_CTL_API_BIND=127.0.0.1:8787
