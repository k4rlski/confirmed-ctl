# confirmed-ctl configuration. Copy to `.env` and fill in real values.
# The real .env file is git-ignored and must never be committed.

# Database (your existing Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/your_db

# Gmail (read-only, service-account with domain-wide delegation)
# Path to the Google service-account JSON key file (a secret on disk).
GMAIL_TOKEN_PATH=/opt/confirmed-ctl/gmail_token.json
# Mailbox the service account impersonates. Default karl@perm-ads.com: it holds
# the BofA alerts in its DURABLE INBOX (not Trash) and also receives Paul's info@
# vendor ad-confirmation emails that this tool searches by CRM ad number. The
# scan still lists with includeSpamTrash=True defensively.
# Alternatives (override this value):
#   info@perm-ads.com  — the delivery address; a filter auto-trashes BofA alerts
#                        there and Gmail purges Trash after ~30 days (run daily).
#   <admin mailbox>    — the non-forwarded admin account (e.g. admin@perm-ads.com).
GMAIL_IMPERSONATE=karl@perm-ads.com

# Email-scan ingestion
# Default lookback window (days) for the BofA transaction-alert scan. Keep the
# scan on a DAILY schedule so Trash auto-purge (~30 days) never drops an alert.
EMAIL_SCAN_LOOKBACK_DAYS=2

# Receipts storage
RECEIPTS_BASE_PATH=/mnt/receipts

# ChromaDB
CHROMA_PATH=/opt/confirmed-ctl/chroma_db

# Sync interval for daemon (seconds)
SYNC_INTERVAL_SECONDS=3600
